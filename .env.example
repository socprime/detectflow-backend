# Admin Panel Backend Configuration

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=INFO

# ==========================================
# FLINK PIPELINE DEFAULTS
# ==========================================
# Default resources per Flink TaskManager (each TM = one parallelism unit)
FLINK_TASKMANAGER_CPU=1.0          # CPU cores per TaskManager (default: 1.0)
FLINK_TASKMANAGER_MEMORY_GB=2      # Memory per TaskManager in GB

# JobManager resources
FLINK_JOBMANAGER_CPU=1.0
FLINK_JOBMANAGER_MEMORY_GB=2

# ==========================================
# AUTOSCALER QUOTAS (Per-Pipeline Limits)
# ==========================================
# Optional: Override per-pipeline autoscaler limits
# If not set, auto-calculated from TaskManager resources
# AUTOSCALER_QUOTA_CPU=3.0
# AUTOSCALER_QUOTA_MEMORY_GB=4

# ==========================================
# FLINK PROVIDER
# ==========================================
# Provider selection: "kubernetes" (Flink Operator) or "cmf" (Confluent Manager)
FLINK_PROVIDER=kubernetes

# ==========================================
# KUBERNETES CONNECTION (when FLINK_PROVIDER=kubernetes)
# ==========================================
KUBERNETES_NAMESPACE=security
FLINK_IMAGE=flink-sigma-detector:latest
IMAGE_PULL_POLICY=Never
FLINK_IMAGE_CMF=flink-sigma-detector:latest

# ==========================================
# CMF CONNECTION (when FLINK_PROVIDER=cmf)
# ==========================================
# CMF API URL (required for CMF provider)
# CMF_URL=http://cmf-service.confluent:80
# CMF environment name (required for CMF provider)
# CMF_ENVIRONMENT=default
# Kubernetes namespace where CMF deploys Flink apps (required for CMF provider)
# CMF_NAMESPACE=confluent

# CMF mTLS authentication (optional, for external access)
# CMF_CLIENT_CERT_PATH=/path/to/client.crt
# CMF_CLIENT_KEY_PATH=/path/to/client.key
# CMF_CA_CERT_PATH=/path/to/ca.crt

# Flink metrics polling interval (seconds)
FLINK_METRICS_POLL_INTERVAL=5.0

# ==========================================
# RESOURCE MANAGEMENT
# ==========================================
# IMPORTANT: Cluster-wide resource limits are managed via Kubernetes ResourceQuota
# NOT via application-level config. See k8s/resource-quota.yaml
#
# To configure cluster capacity:
# 1. Edit k8s/resource-quota.yaml with your cluster's available resources
# 2. Apply: kubectl apply -f k8s/resource-quota.yaml
# 3. View usage: kubectl describe resourcequota -n security
#
# Example ResourceQuota for 8 cores, 12 GB cluster:
#   requests.cpu: "6"       # 8 total - 2 reserved for system
#   requests.memory: "8Gi"  # 12 total - 4 reserved for system

# ==========================================
# DATABASE
# ==========================================
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/admin_panel

# ==========================================
# KAFKA CONFIGURATION
# ==========================================
KAFKA_BOOTSTRAP_SERVERS=srv-mlk-001.cloud.socprime.com:9092
KAFKA_AUTH_METHOD=PLAINTEXT
# Disable SSL hostname verification (for self-signed certs)
KAFKA_SSL_CHECK_HOSTNAME=false

# For SASL auth:
# KAFKA_AUTH_METHOD=SASL
# KAFKA_API_KEY=your-api-key
# KAFKA_API_SECRET=your-api-secret
# For SSL auth:
# KAFKA_AUTH_METHOD=SSL
# KAFKA_SSL_CA_LOCATION=/path/to/ca.pem
# KAFKA_SSL_CERTIFICATE_LOCATION=/path/to/cert.pem
# KAFKA_SSL_KEY_LOCATION=/path/to/key.pem

# Kafka topics
KAFKA_SIGMA_RULES_TOPIC=sigma-rules
KAFKA_METRICS_TOPIC=rule-statistics
KAFKA_METRICS_CONSUMER_GROUP=admin-panel-metrics
# Default partitions and replication for new topics (used by entrypoint.sh)
KAFKA_DEFAULT_PARTITIONS=1
KAFKA_DEFAULT_REPLICATION_FACTOR=2

# ==========================================
# DASHBOARD SETTINGS
# ==========================================
# SSE broadcast interval (seconds)
DASHBOARD_BROADCAST_INTERVAL_SECONDS=2.0

# ==========================================
# JWT AUTHENTICATION
# ==========================================
# IMPORTANT: Change these in production!
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_REFRESH_SECRET_KEY=your-refresh-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# AUDIT LOGS
# ==========================================
# Retention period for audit logs (days)
AUDIT_LOGS_RETENTION_DAYS=30

# ==========================================
# TDM API INTEGRATION
# ==========================================
TDM_API_BASE_URL=https://api.tdm.socprime.com
TDM_HOSTNAME=tdm.socprime.com

# ==========================================
# ACTIVITY TRACKING
# ==========================================
KAFKA_ACTIVITY_TOPIC=etl-activity
KAFKA_ACTIVITY_CONSUMER_GROUP=admin-panel-activity

# ==========================================
# AUTO SYNC (Optional)
# ==========================================
# Enable automatic scheduled sync of repositories
ENABLE_AUTO_SYNC=false
SYNC_API_REPOS_INTERVAL_MINUTES=5
SYNC_API_REPOS_TIMEOUT_SECONDS=600

# Scheduled health check (check_all) interval when scheduler is running (minutes)
HEALTH_CHECK_INTERVAL_MINUTES=5

FLINK_CHECKPOINTS_PVC=my-checkpoints-pvc
FLINK_HA_PVC=my-ha-pvc
FLINK_SAVEPOINTS_PVC=my-savepoints-pvc
